# ── 生产部署必需：覆盖 docker-compose.yml 的默认密码 ──
# 复制为 .env 并修改：
#   cp .env.example .env

# PostgreSQL
PG_USER=quality_gates
PG_PASSWORD=quality_gates
PG_DB=quality_gates

# Unleash
UNLEASH_ADMIN_PASSWORD=admin123
UNLEASH_TOKEN=default:development.unleash-insecure-api-token
UNLEASH_AUTH_TYPE=none

# LLM (agent-prod 服务)
OPENAI_API_KEY=