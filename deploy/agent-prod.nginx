# agent-prod nginx config — TLS termination + upstream load-balancing
#
# 部署:
#   cp agent-prod.nginx /etc/nginx/sites-available/agent-prod
#   ln -s /etc/nginx/sites-available/agent-prod /etc/nginx/sites-enabled/
#   certbot --nginx -d quality-gates.example.com
#   systemctl reload nginx
#
# upstream 里的 server 数量 = 启动时 --replicas 决定的进程数
# 每个进程监听独立端口（8765, 8766, ...）

upstream agent_prod_backend {
    # 最少 2 副本生产可用；扩展时追加即可
    server 127.0.0.1:8765 max_fails=3 fail_timeout=30s;
    server 127.0.0.1:8766 max_fails=3 fail_timeout=30s;
    # server 127.0.0.1:8767 max_fails=3 fail_timeout=30s;

    keepalive 32;
}

# ── HTTP → HTTPS redirect ──
server {
    listen 80;
    server_name quality-gates.example.com;  # ← 改为你的域名

    location / {
        return 301 https://$host$request_uri;
    }

    # Let's Encrypt validation
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
}

# ── HTTPS API ──
server {
    listen 443 ssl http2;
    server_name quality-gates.example.com;  # ← 改为你的域名

    # TLS — certbot 自动管理
    ssl_certificate     /etc/letsencrypt/live/quality-gates.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/quality-gates.example.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;

    # 安全头
    add_header Strict-Transport-Security "max-age=63072000" always;
    add_header X-Content-Type-Options nosniff;
    add_header X-Frame-Options DENY;

    # 公网只暴露 evaluate 和 health
    location /health  { proxy_pass http://agent_prod_backend/health; }
    location /ready   { proxy_pass http://agent_prod_backend/ready; }
    location /metrics { proxy_pass http://agent_prod_backend/metrics; }
    location /v1/agent/evaluate       { proxy_pass http://agent_prod_backend/v1/agent/evaluate; }
    location /v1/agent/evaluate/dry-run { proxy_pass http://agent_prod_backend/v1/agent/evaluate/dry-run; }
    location /v1/agent/thresholds     { proxy_pass http://agent_prod_backend/v1/agent/thresholds; }
    location /v1/agent/types          { proxy_pass http://agent_prod_backend/v1/agent/types; }
    location /sessions                { proxy_pass http://agent_prod_backend/sessions; }

    # 代理设置
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_read_timeout 60s;
    proxy_send_timeout 60s;

    # 客户端限流 — nginx 层面兜底
    limit_req zone=api burst=100 nodelay;
    limit_req_status 429;
}
