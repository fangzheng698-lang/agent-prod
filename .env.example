# ── LLM Provider ──
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── Storage ──
STORAGE_BACKEND=file           # memory | file | postgres
STORAGE_POSTGRES_DSN=postgresql://quality_gates:quality_gates_dev@localhost:5432/quality_gates

# ── Agent ──
MAX_TURNS=50
MAX_TOKENS=100000